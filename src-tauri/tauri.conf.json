{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Convocacao",
  "version": "1.0.3",
  "identifier": "com.iguacu.convocacao",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/ronyiguacu/convocacao-cliente/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQxRDlBQUI2OEE0Qzc2QkEKUldTNmRreUt0cXJaMFNnQnJNNnZtNVhJeVViY2JKbXNUZWJhRmlSYmZ6MkV0K3JYUllxbldSZ2YK"
    }
  }
}
